# ─── Backend ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
MONGO_URI=mongodb://localhost:27017/tmpmail
PORT=4000

# Comma-separated list of available domains
DOMAINS=domain1.com,domain2.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10

# Mailbox TTL in seconds (default: 600 = 10 min)
MAILBOX_TTL=600
# Seconds added per received email (default: 300 = 5 min)
MAILBOX_TTL_EXTEND=300

# Max attachment size in bytes (default: 5MB)
MAX_ATTACHMENT_SIZE=5242880

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=es

# ─── Security ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
